---
import Layout from '../layouts/Layout.astro';
---
<Layout currentPath="/">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge">✨ 業界15年以上・静岡県西部No.1優良店</div>
    <h1>
      浜松の<span>コンパニオン派遣</span>なら<br />
      SHINRAにお任せください！
    </h1>
    <p class="hero-sub">
      宴会・懇親会・パーティー・企業イベントに対応。<br />
      明るくて気さくな女の子が盛り上げます♪<br />
      <strong>2時間女の子2人〜 15,000円〜</strong>
    </p>
    <div class="hero-btns">
      <a href="https://page.line.me/225deoky" class="btn-line" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;fill:#fff;"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
        LINEで無料相談
      </a>
      <a href="tel:08042248880" class="btn-primary">📞 080-4224-8880</a>
      <a href="/yoyaku/" class="btn-outline">仮予約フォーム</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">15年</div>
        <div class="hero-stat-label">業界実績</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">150名</div>
        <div class="hero-stat-label">在籍スタッフ数</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">2名〜</div>
        <div class="hero-stat-label">2時間15,000円〜</div>
      </div>
    </div>
  </section>

  <!-- APPEAL BAR -->
  <div class="appeal-bar">
    <div class="appeal-bar-inner">
      <div class="appeal-item">
        <div class="appeal-icon">👧</div>
        <div class="appeal-title">在籍150名超</div>
      </div>
      <div class="appeal-item">
        <div class="appeal-icon">🏆</div>
        <div class="appeal-title">業界15年以上の実績</div>
      </div>
      <div class="appeal-item">
        <div class="appeal-icon">📍</div>
        <div class="appeal-title">浜松市内〜静岡西部対応</div>
      </div>
    </div>
  </div>

  <!-- GALLERY -->
  <section id="gallery">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">STAFF PHOTO</div>
        <h2 class="section-title">スタッフ紹介</h2>
        <p class="section-lead">
          OL・大学生・看護師など幅広い職種の20〜30代前半の女の子が在籍。<br />
          明るくて気さくなスタッフが宴会を盛り上げます♪
        </p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item wide">
          <img src="/images/girl4.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl1.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl2.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl3.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl5.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl6.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl7.jpg" alt="浜松コンパニオン SHINRAスタッフ" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">FEATURES</div>
        <h2 class="section-title">SHINRAが<span>選ばれる理由</span></h2>
        <p class="section-lead">お客様に安心してご利用いただける理由</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🏆</div>
          <div class="feature-title">業界15年以上の実績</div>
          <p class="feature-text">静岡県西部No.1優良店としてお客様に支持されてきた長年の実績。安心してお任せください。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">👧</div>
          <div class="feature-title">在籍150名超の豊富な人材</div>
          <p class="feature-text">OL・大学生・看護師など多様な職種の女の子が在籍。ご要望に合ったスタッフをご提案します。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💴</div>
          <div class="feature-title">わかりやすい料金システム</div>
          <p class="feature-text">2時間女の子2人〜15,000円の明朗会計。お見積もり無料です。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📍</div>
          <div class="feature-title">浜松市内〜静岡西部全域対応</div>
          <p class="feature-text">浜松市はもちろん、磐田・袋井・掛川・菊川・湖西など静岡県西部全域に対応しています。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📞</div>
          <div class="feature-title">丁寧なヒアリング</div>
          <p class="feature-text">人数・予算・雰囲気など事前にしっかりお聞きします。初めての方でも安心してお任せください。</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🛡️</div>
          <div class="feature-title">安心・安全なサービス</div>
          <p class="feature-text">ピンクコンパニオンは一切なし。スタッフの安全を守り、お客様にも安心してご利用いただけます。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICE (summary) -->
  <section id="ryokin" style="background:var(--pink-bg);">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">PRICE</div>
        <h2 class="section-title">料金システム<span>（概要）</span></h2>
        <p class="section-lead">お見積もり無料です。まずはご相談ください</p>
      </div>
      <!-- 基本料金 -->
      <div class="price-table-wrap" style="max-width:480px;margin:0 auto 28px;">
        <table class="price-table">
          <thead>
            <tr><th>項目</th><th>料金（税込）</th></tr>
          </thead>
          <tbody>
            <tr><td>2時間 女の子2人〜</td><td class="price-highlight">15,000円〜</td></tr>
            <tr><td>延長1時間</td><td class="price-highlight">8,000円</td></tr>
            <tr><td>指名料</td><td class="price-highlight">1,000円</td></tr>
          </tbody>
        </table>
      </div>
      <!-- 人数別 -->
      <div class="price-table-wrap">
        <table class="price-table">
          <thead>
            <tr><th>人数</th><th>2時間コース（+交通費）</th></tr>
          </thead>
          <tbody>
            <tr><td>2人</td><td class="price-highlight">30,000円</td></tr>
            <tr><td>3人</td><td class="price-highlight">45,000円</td></tr>
            <tr><td>4人</td><td class="price-highlight">60,000円</td></tr>
            <tr><td>5人</td><td class="price-highlight">75,000円</td></tr>
            <tr><td>6人</td><td class="price-highlight">90,000円</td></tr>
            <tr><td>7人</td><td class="price-highlight">105,000円</td></tr>
            <tr><td>8人</td><td class="price-highlight">120,000円</td></tr>
            <tr><td>9人</td><td class="price-highlight">135,000円</td></tr>
            <tr><td>10人以上</td><td class="price-highlight">電話にて確認</td></tr>
          </tbody>
        </table>
      </div>
      <div class="price-notes">
        <div class="price-note">指名料：1,000円/名</div>
        <div class="price-note">交通費：浜松市中心部は無料。市内1,000円、周辺市町村2,000〜3,000円</div>
        <div class="price-note">繁忙期（10月〜1月）：キャスト1名・1時間あたり500円UP</div>
      </div>
      <div style="text-align:center;margin-top:28px;">
        <a href="/ryokin/" class="btn-outline">詳しい料金を見る</a>
      </div>
    </div>
  </section>

  <!-- VOICE -->
  <section id="voice">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">VOICE</div>
        <h2 class="section-title">お客様の<span>声</span></h2>
      </div>
      <div class="voice-grid">
        <div class="voice-card">
          <p class="voice-text">女の子のレベルが本当に高くてびっくりしました！宴会が何倍も盛り上がって大満足です。また絶対使います！</p>
          <div class="voice-from">— 浜松市・会社宴会でご利用</div>
        </div>
        <div class="voice-card">
          <p class="voice-text">初めてコンパニオンを頼んだのですが、丁寧に説明してもらえて安心できました。スタッフの子もとても気さくで楽しかったです♪</p>
          <div class="voice-from">— 磐田市・懇親会でご利用</div>
        </div>
        <div class="voice-card">
          <p class="voice-text">急な依頼にも関わらず対応してもらえました。料金も明確でわかりやすく、安心して利用できました。</p>
          <div class="voice-from">— 袋井市・パーティーでご利用</div>
        </div>
        <div class="voice-card">
          <p class="voice-text">15年以上の実績があるだけあって、対応がとてもプロフェッショナル。毎年お願いしています！</p>
          <div class="voice-from">— 浜松市・毎年ご利用</div>
        </div>
      </div>
    </div>
  </section>

  <!-- AREA -->
  <section id="area">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">SERVICE AREA</div>
        <h2 class="section-title">対応<span>エリア</span></h2>
        <p class="section-lead">浜松市内はもちろん、静岡県西部全域に対応しています</p>
      </div>
      <div class="area-grid">
        <div class="area-card">
          <div class="area-name">浜松市街中</div>
          <div class="area-fee">交通費：無料</div>
        </div>
        <div class="area-card">
          <div class="area-name">浜松市内</div>
          <div class="area-fee">交通費：1,000円/名</div>
        </div>
        <div class="area-card">
          <div class="area-name">湖西市・磐田市・袋井市・掛川市</div>
          <div class="area-fee">交通費：2,000円/名</div>
        </div>
        <div class="area-card" style="border-color:var(--pink);">
          <div class="area-name">菊川市・御前崎市・牧之原市・島田市</div>
          <div class="area-fee">交通費：3,000円/名</div>
        </div>
      </div>
      <div style="text-align:center;margin-top:24px;">
        <a href="/area/" class="btn-outline">エリア詳細を見る</a>
      </div>
    </div>
  </section>

  <!-- FLOW -->
  <section id="flow" style="background:var(--pink-bg);">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">FLOW</div>
        <h2 class="section-title">ご利用の<span>流れ</span></h2>
      </div>
      <div style="max-width:680px;margin:0 auto;">
        {[
          { num: 1, title: '利用規約を確認する', desc: 'ご利用前に必ず利用規約をご確認ください。18歳未満の方はご利用いただけません。' },
          { num: 2, title: '会場に確認する', desc: 'コンパニオンが入店できる会場かどうかを事前に施設に確認してください。' },
          { num: 3, title: '仮予約をする', desc: '電話・LINE・仮予約フォームにて、ご希望の日時・人数・会場・コース時間をお知らせください。' },
          { num: 4, title: '24時間以内に確認連絡', desc: 'スタッフの空き状況を確認し、24時間以内にご連絡します。' },
          { num: 5, title: '前日に最終確認', desc: 'ご予約前日にスタッフより確認のご連絡をします。' },
          { num: 6, title: '当日・開始10分前に到着', desc: 'スタッフが会場へ伺います。開始時間の10分前を目安にお越しします。' },
          { num: 7, title: '終了・お会計', desc: '終了時間の30分前に延長される場合はお知らせください。終了後にお会計となります。' },
        ].map(step => (
          <div style="display:grid;grid-template-columns:60px 1fr;gap:16px;padding:20px 0;border-bottom:1px solid var(--border);">
            <div style="text-align:center;padding-top:2px;">
              <div class="flow-num" style="margin:0 auto;">{step.num}</div>
            </div>
            <div>
              <div class="flow-title">{step.title}</div>
              <p class="flow-text" style="margin-top:4px;">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:28px;">
        <a href="/hajimete/" class="btn-outline">初めての方はこちら</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">FAQ</div>
        <h2 class="section-title">よくある<span>ご質問</span></h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-q">浜松でコンパニオンを初めて頼むのですが大丈夫ですか？</div>
          <div class="faq-a">もちろんです！初めての方でも丁寧にご説明しますので安心してお任せください。まずはLINEでお気軽にご相談ください♪</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">浜松市のどのエリアでも対応できますか？</div>
          <div class="faq-a">浜松市内全域に対応しています。中心部は交通費無料、郊外エリアは1,000円です。磐田・袋井・掛川などの周辺市町村も対応しています。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">何名から依頼できますか？</div>
          <div class="faq-a">基本は2時間女の子2名〜のご対応となります。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">浜松コンパニオンの料金はいくらですか？</div>
          <div class="faq-a">2時間女の子2名〜15,000円です。指名料1,000円・延長1時間8,000円。詳しくは料金ページをご覧ください。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">ピンクコンパニオンはありますか？</div>
          <div class="faq-a">ピンクコンパニオンのご提供は一切行っておりません。安心・安全なサービスをご提供しています。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">どんな宴会に対応していますか？</div>
          <div class="faq-a">会社宴会・懇親会・忘年会・新年会・歓送迎会・パーティー・各種お祝いの席など幅広く対応しています。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SEO CONTENT -->
  <section class="seo-section" style="padding:64px 24px;">
    <div class="section-inner">
      <div class="seo-columns">
        <div class="seo-text">
          <h3>浜松市のコンパニオン派遣について</h3>
          <p>浜松市は静岡県最大の都市であり、企業の宴会・懇親会・各種パーティーが盛んに行われています。SHINRAは浜松市を中心に業界15年以上の実績を持つコンパニオン派遣サービスです。</p>
          <p>浜松市内の居酒屋・料亭・ホテル宴会場など、あらゆる会場へスタッフを派遣いたします。浜松市は2024年1月の区再編により現在は<strong>中央区・浜名区・天竜区</strong>の3区制です。市内全域に対応しています。</p>
        </div>
        <div class="seo-text">
          <h3>浜松コンパニオンの選び方</h3>
          <p>コンパニオン派遣を初めてご利用になる場合、「料金が明確か」「実績があるか」「スタッフの質が高いか」の3点が重要です。</p>
          <p>SHINRAは料金を事前に明示します。15年以上の実績と150名超の在籍スタッフ数が信頼の証です。浜松で宴会コンパニオンをお探しなら、まずはSHINRAへお気軽にご相談ください。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="section-inner">
      <div class="section-head">
        <div class="section-tag">CONTACT</div>
        <h2 class="section-title">お気軽に<span>ご相談ください</span></h2>
        <p class="section-lead">LINEが一番スムーズです！お見積もり無料♪</p>
      </div>
      <div class="contact-grid">
        <div class="contact-card">
          <div class="contact-card-title">📞 お電話でのご相談</div>
          <a href="tel:08042248880" class="contact-tel-num">080-4224-8880</a>
        </div>
        <div class="contact-card">
          <div class="contact-card-title">💬 LINEでのご相談</div>
          <a href="https://page.line.me/225deoky" class="btn-line" target="_blank" rel="noopener noreferrer" style="margin:0 auto;display:inline-flex;">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;fill:#fff;"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            LINEを開く
          </a>
          <p class="contact-time" style="margin-top:8px;font-size:0.72rem;color:var(--gray-light);">24時間メッセージ受付</p>
        </div>
      </div>
      <div class="inline-form">
        <h3>📝 仮予約フォーム</h3>
        <form action="https://formspree.io/f/shinra" method="POST">
          <div class="form-row">
            <label>代表者氏名（フルネーム）<span class="req">必須</span></label>
            <input type="text" name="name" placeholder="例：山田 太郎" required />
          </div>
          <div class="form-row">
            <label>フリガナ（フルネーム）<span class="req">必須</span></label>
            <input type="text" name="furigana" placeholder="例：ヤマダ タロウ" required />
          </div>
          <div class="form-row">
            <label>メールアドレス <span class="req">必須</span></label>
            <input type="email" name="email" placeholder="example@gmail.com" required />
          </div>
          <div class="form-row">
            <label>連絡先電話番号 <span class="req">必須</span></label>
            <input type="tel" name="tel" placeholder="例：090-0000-0000" required />
          </div>
          <div class="form-row">
            <label>コンパニオンご希望人数 <span class="req">必須</span></label>
            <select name="people" required>
              <option value="">選択してください</option>
              <option value="2名">2名</option>
              <option value="3名">3名</option>
              <option value="4名">4名</option>
              <option value="5名">5名</option>
              <option value="6名">6名</option>
              <option value="7名">7名</option>
              <option value="8名">8名</option>
              <option value="9名">9名</option>
              <option value="10名以上">10名以上</option>
            </select>
          </div>
          <div class="form-row">
            <label>ご宴会予定日 <span class="req">必須</span></label>
            <input type="text" name="date" placeholder="例：2024年12月20日（金）" required />
          </div>
          <div class="form-row">
            <label>ご宴会開始予定の時間 <span class="req">必須</span></label>
            <input type="text" name="start_time" placeholder="例：18:00" required />
          </div>
          <div class="form-row">
            <label>ご宴会予定の場所（店名）<span class="req">必須</span></label>
            <input type="text" name="venue_name" placeholder="例：〇〇料亭" required />
          </div>
          <div class="form-row">
            <label>ご宴会予定の場所（住所）<span class="req">必須</span></label>
            <input type="text" name="venue_address" placeholder="例：浜松市中央区〇〇町1-2-3" required />
          </div>
          <div class="form-row">
            <label>お客様人数や団体名 <span class="req">必須</span></label>
            <input type="text" name="guests" placeholder="例：20名・〇〇株式会社" required />
          </div>
          <div class="form-row">
            <label>コンパニオン延長の可能性 <span class="req">必須</span></label>
            <select name="extension" required>
              <option value="">選択してください</option>
              <option value="あり">あり</option>
              <option value="なし">なし</option>
              <option value="わからない">わからない</option>
            </select>
          </div>
          <div class="form-row">
            <label>領収書</label>
            <select name="receipt">
              <option value="不要">不要</option>
              <option value="必要">必要</option>
            </select>
          </div>
          <div class="form-row">
            <label>領収書宛名</label>
            <input type="text" name="receipt_name" placeholder="領収書が必要な場合はご記入ください" />
          </div>
          <div class="form-row">
            <label>その他お問い合わせ事項</label>
            <textarea name="message" placeholder="ご要望・ご質問などがあればご記入ください"></textarea>
          </div>
          <p style="font-size:0.75rem;color:var(--gray-light);margin-bottom:16px;line-height:1.8;">
            ※ 携帯メールアドレスでインターネットメール拒否設定をされている方は、ドメイン指定受信で <strong>gmail.com</strong> を許可ドメインに追加してください。
          </p>
          <button type="submit" class="btn-submit">仮予約を送信する</button>
        </form>
      </div>
    </div>
  </section>

</Layout>
