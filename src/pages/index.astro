---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <!-- HEADER -->
  <header>
    <div class="logo">
      森羅
      <span>SHINRA COMPANION / HAMAMATSU</span>
    </div>
    <nav>
      <a href="#gallery">フォトギャラリー</a>
      <a href="#about">森羅について</a>
      <a href="#flow">ご利用の流れ</a>
      <a href="#faq">よくある質問</a>
      <a href="#contact">お問い合わせ</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <p class="hero-label">Hamamatsu Premium Companion</p>
      <h1>
        浜松で選ばれる<br />
        <em>上質なおもてなし</em>
      </h1>
      <p class="hero-sub">宴会・パーティー・各種イベントに対応</p>
      <a href="#contact" class="hero-cta">無料相談・お問い合わせ</a>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery">
    <div class="gallery-inner">
      <div class="gallery-header">
        <p class="section-label">Photo Gallery</p>
        <h2 class="section-title">スタッフ紹介</h2>
        <div class="divider" style="margin: 24px auto;"></div>
        <p class="section-lead">
          明るく・上品で・気さくなスタッフが揃っております。<br />
          大切な場を共に盛り上げるパートナーをお選びください。
        </p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item large">
          <img src="/images/girl4.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl1.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl2.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl3.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl5.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl6.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
        <div class="gallery-item">
          <img src="/images/girl7.jpg" alt="浜松コンパニオン スタッフ" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="about-inner">
      <div class="about-text">
        <p class="section-label">About</p>
        <h2 class="section-title">森羅について</h2>
        <div class="divider"></div>
        <p>
          森羅は浜松を中心に活動するコンパニオン派遣サービスです。
          宴会・パーティー・各種イベントに、明るく上品なスタッフを派遣いたします。
        </p>
        <p>
          お客様に心から楽しんでいただけるよう、スタッフ一同丁寧な対応を心がけております。
          初めてのご利用の方も、お気軽にご相談ください。
        </p>
        <p>
          浜松市内はもちろん、周辺エリアへの出張も承っております。
          まずはお電話またはLINEにてお気軽にお問い合わせください。
        </p>
      </div>
      <div class="about-image">
        <img src="/images/girl5.jpg" alt="森羅 浜松コンパニオン" />
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section id="features">
    <div class="features-inner">
      <div class="features-header">
        <p class="section-label">Features</p>
        <h2 class="section-title">森羅が選ばれる理由</h2>
        <div class="divider" style="margin: 24px auto;"></div>
        <p class="section-lead">
          お客様に安心してご利用いただけるよう、<br />3つのこだわりをお約束します。
        </p>
      </div>
      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-num">01</div>
          <div class="feature-title">厳選されたスタッフ</div>
          <p class="feature-text">
            容姿・マナー・コミュニケーション力を兼ね備えたスタッフのみを厳選採用。
            大切なお席に最適な人材をご提案します。
          </p>
        </div>
        <div class="feature-item">
          <div class="feature-num">02</div>
          <div class="feature-title">丁寧なヒアリング</div>
          <p class="feature-text">
            ご要望・人数・予算・雰囲気など、事前にしっかりお伺いします。
            初めてのご利用でも安心してお任せください。
          </p>
        </div>
        <div class="feature-item">
          <div class="feature-num">03</div>
          <div class="feature-title">明確な料金体系</div>
          <p class="feature-text">
            追加料金なし・明朗会計でご安心いただけます。
            お見積もりは無料ですので、お気軽にお問い合わせください。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FLOW -->
  <section id="flow">
    <div class="flow-header">
      <p class="section-label">Flow</p>
      <h2 class="section-title">ご利用の流れ</h2>
      <div class="divider" style="margin: 24px auto;"></div>
    </div>
    <div class="flow-steps">
      <div class="flow-step">
        <div class="flow-num">STEP<br />01</div>
        <div>
          <div class="flow-title">お問い合わせ</div>
          <p class="flow-desc">
            お電話またはLINEにてご連絡ください。日程・人数・ご予算などをお聞かせいただければスムーズです。
          </p>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">STEP<br />02</div>
        <div>
          <div class="flow-title">ご相談・お見積もり</div>
          <p class="flow-desc">
            ご希望の内容をもとに最適なプランをご提案。料金・スタッフ人数・当日の流れについてご説明します。
          </p>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">STEP<br />03</div>
        <div>
          <div class="flow-title">ご予約確定</div>
          <p class="flow-desc">
            内容にご納得いただければご予約確定。前日に確認のご連絡を差し上げます。
          </p>
        </div>
      </div>
      <div class="flow-step">
        <div class="flow-num">STEP<br />04</div>
        <div>
          <div class="flow-title">当日・おもてなし</div>
          <p class="flow-desc">
            スタッフが会場へ伺い、お席を盛り上げます。終了後にお会計となります。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq">
    <div class="faq-inner">
      <div class="faq-header">
        <p class="section-label">FAQ</p>
        <h2 class="section-title">よくある質問</h2>
        <div class="divider" style="margin: 24px auto;"></div>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-q">初めてでも依頼できますか？</div>
          <div class="faq-a">もちろんです。初めてのご利用の方でも丁寧にご説明しますので、お気軽にご連絡ください。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">何名から依頼できますか？</div>
          <div class="faq-a">1名様から承っております。人数に応じてご提案いたします。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">浜松市外でも対応していただけますか？</div>
          <div class="faq-a">はい、静岡県内を中心に周辺エリアへの出張も承っております。遠方の場合は交通費が別途かかる場合がございます。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">どんなイベントに対応していますか？</div>
          <div class="faq-a">宴会・懇親会・パーティー・企業イベント・各種お祝いの席など、幅広くご対応いたします。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">料金を教えてください。</div>
          <div class="faq-a">内容によって異なるため、まずはお問い合わせください。無料でお見積もりいたします。追加料金は一切ございません。</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">当日キャンセルはできますか？</div>
          <div class="faq-a">キャンセルポリシーについてはご予約時にご説明いたします。なるべく早めにご連絡いただけますと幸いです。</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="contact-inner">
      <p class="section-label">Contact</p>
      <h2 class="section-title">お問い合わせ</h2>
      <div class="divider" style="margin: 24px auto;"></div>
      <p class="contact-lead">
        ご予約・ご相談はお電話またはLINEにてお気軽にどうぞ。<br />
        お見積もりは無料です。まずはお気軽にお問い合わせください。
      </p>
      <div class="contact-tel">📞 お問い合わせはLINEから</div>
      <p class="contact-time">受付時間 10:00〜22:00</p>
      <a href="https://lin.ee/XXXXXXX" class="btn-line" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:24px;height:24px;fill:#fff;">
          <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
        </svg>
        LINEで無料相談する
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-logo">森羅</div>
    <p class="footer-address">
      浜松市｜コンパニオン派遣サービス<br />
      受付時間：10:00〜22:00
    </p>
    <p class="footer-copy">&copy; 2024 森羅 All Rights Reserved.</p>
  </footer>

  <!-- LINE FLOAT BUTTON -->
  <div class="line-float">
    <a href="https://lin.ee/XXXXXXX" target="_blank" rel="noopener noreferrer" aria-label="LINEでお問い合わせ">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
      </svg>
    </a>
    <span class="line-float-label">LINE相談</span>
  </div>
</Layout>
